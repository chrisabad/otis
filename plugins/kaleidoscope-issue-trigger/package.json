{
  "name": "@kaleidoscope/paperclip-issue-trigger",
  "version": "1.44.0",
  "description": "Triggers agent heartbeats when new todo issues are created in PaperClip",
  "type": "module",
  "main": "dist/worker.js",
  "paperclip": {
    "manifest": "dist/manifest.js"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:scripts": "tsx src/__tests__/dcw-suppression.test.ts",
    "lint": "biome lint src",
    "format:check": "biome format src"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "2026.318.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^25.6.0",
    "esbuild": "^0.20.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
